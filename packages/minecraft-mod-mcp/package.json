{
  "name": "minecraft-mod-mcp",
  "version": "0.1.1",
  "description": "MCP server bridge for Minecraft — connect AI tools to Minecraft via Model Context Protocol",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "minecraft-mod-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "minecraft",
    "mcp",
    "model-context-protocol",
    "ai",
    "automation",
    "forge",
    "fabric",
    "neoforge"
  ],
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/langyo/minecraft-mod-mcp.git",
    "directory": "packages/minecraft-mod-mcp"
  },
  "homepage": "https://github.com/langyo/minecraft-mod-mcp#readme",
  "bugs": {
    "url": "https://github.com/langyo/minecraft-mod-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  }
}
