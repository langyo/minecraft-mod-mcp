{
  "productName": "MMML",
  "version": "0.1.0",
  "identifier": "xyz.langyo.minecraft.mmml",
  "build": {
    "beforeBuildCommand": "pnpm --dir ../frontend build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MMML",
        "width": 1024,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ws://localhost:* http://localhost:* https://localhost:*; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
